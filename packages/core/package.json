{
  "name": "@projectcrossplay/core",
  "version": "0.1.1",
  "description": "CrossPlay core: unified test API, selector engine, auto-wait engine, trace writer, driver contract",
  "license": "Apache-2.0",
  "keywords": ["testing", "e2e", "automation", "cross-platform", "crossplay"],
  "repository": {
    "type": "git",
    "url": "https://github.com/ProjectCrossPlay/projectcrossplay.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ProjectCrossPlay/projectcrossplay#readme",
  "bugs": {
    "url": "https://github.com/ProjectCrossPlay/projectcrossplay/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test": {
      "types": "./dist/test-entry.d.ts",
      "default": "./dist/test-entry.js"
    },
    "./global-setup": {
      "types": "./dist/global-setup.d.ts",
      "default": "./dist/global-setup.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests"
  },
  "peerDependencies": {
    "vitest": "^3.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  }
}
